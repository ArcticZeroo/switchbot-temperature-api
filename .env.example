# SwitchBot Climate API configuration
# Copy this file to .env and fill in your values.

# Required: SwitchBot API credentials
# Get these from the SwitchBot app: Profile → Preferences → tap App Version 10× → Developer Options
SWITCHBOT_TOKEN=your-switchbot-token-here
SWITCHBOT_SECRET=your-switchbot-secret-here

# Required for `serve`: Device ID of your SwitchBot Hub / Meter
# Run `switchbot-api discover` to find this value
SWITCHBOT_DEVICE_ID=your-device-id-here

# Optional: Path to SQLite database file (default: climate.db)
# DATABASE_PATH=climate.db

# Optional: Address to listen on (default: 0.0.0.0:3000)
# LISTEN_ADDR=0.0.0.0:3000
